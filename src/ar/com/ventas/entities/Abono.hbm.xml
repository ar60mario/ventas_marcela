<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD//EN" "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class name="ar.com.ventas.entities.Abono" schema="marce" table="abono">
        <id name="id" column="ID">
            <generator class="identity"/>
        </id>
        <property name="codigo" type="integer" column="CODIGO"/>
        <property name="activo" type="boolean" column="ACTIVO"/>
        <property name="generado" type="boolean" column="GENERADO"/>
        <property name="importe" type="double" column="IMPORTE"/>
        <property name="fechaModif" type="date" column="FECHA_MODIF"/>
        <many-to-one name="cliente"
                    class="ar.com.ventas.entities.Cliente"
                     lazy="false">
                     <column name="ID_Cliente" not-null="true"/>
        </many-to-one>
        <many-to-one name="rubro"
                    class="ar.com.ventas.entities.Rubro"
                     lazy="false">
                     <column name="ID_Rubro" not-null="true"/>
        </many-to-one>
    </class>
</hibernate-mapping>